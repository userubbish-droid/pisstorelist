APP_NAME=食堂厨房库存
SESSION_SECRET=change-me-please
DB_PATH=./data/app.db

# 允许访问的域名（部署到 Hostinger 后把临时域名也加进来）
# 例：localhost,127.0.0.1,mediumvioletred-hawk-262980.hostingersite.com
ALLOWED_HOSTS=localhost,127.0.0.1

# 初始管理员（首次启动会自动创建；已存在则跳过）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# Telegram 低库存提醒（可选；留空则不发送）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 低库存提醒节流（分钟）
TELEGRAM_THROTTLE_MINUTES=360
